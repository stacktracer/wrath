        "@vitejs/plugin-react": "5.0.2",
        "@vitest/browser-playwright": "4.0.0",
        "eslint": "9.35.0",
        "playwright": "1.55.0",
        "prettier": "3.6.2",
        "typescript": "5.9.2",
        "typescript-eslint": "8.42.0",
        "vite": "7.1.5",
        "vitest": "4.0.0"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/material": "^7.3.9",
        "@mui/x-data-grid-pro": "^8.28.2",
        "@mui/x-license": "^8.26.0",
        "@mui/x-tree-view": "^8.27.2",
