{
    "name": "wrath",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "setup": "git config core.hooksPath .githooks",
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
